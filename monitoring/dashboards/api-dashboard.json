{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 0,
  "panels": [
    {
      "type": "timeseries",
      "title": "Requêtes / seconde",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum by (route) (rate(http_requests_total[1m]))",
          "legendFormat": "{{route}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "type": "timeseries",
      "title": "Latence p95 (s)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, route) (rate(http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "{{route}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "type": "stat",
      "title": "Erreurs 5xx / min",
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{status=~\"5..\"}[1m])) * 60",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Process uptime (s)",
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 8 },
      "targets": [
        { "expr": "process_start_time_seconds{job=\"api\"} and time()", "refId": "A" }
      ]
    }
  ],
  "schemaVersion": 39,
  "style": "dark",
  "tags": ["tp-cicd"],
  "templating": { "list": [] },
  "time": { "from": "now-30m", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "TP CI/CD — API Node.js",
  "version": 1,
  "refresh": "10s"
}
