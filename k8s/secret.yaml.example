# NE PAS COMMITTER avec de vraies valeurs.
# Créer le vrai secret côté cluster avec :
#   kubectl create secret generic app-secrets -n tp-cicd \
#     --from-literal=MONGO_USER=appuser \
#     --from-literal=MONGO_PASSWORD='<mot-de-passe>'
apiVersion: v1
kind: Secret
metadata:
  name: app-secrets
  namespace: tp-cicd
type: Opaque
stringData:
  MONGO_USER: "appuser"
  MONGO_PASSWORD: "REPLACE_ME"
